<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nexa Kurs - Ultimate</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Rajdhani:wght@500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --neon-pink: #ff007f;
            --neon-blue: #00f2ff;
            --bg-dark: #050505;
            --card-bg: rgba(15, 15, 20, 0.9);
        }

        body {
            margin: 0; background: var(--bg-dark);
            font-family: 'Rajdhani', sans-serif; color: #fff;
            display: flex; justify-content: center; align-items: center;
            min-height: 100vh; padding: 20px; box-sizing: border-box;
        }

        .app-card {
            width: 100%; max-width: 450px;
            background: var(--card-bg);
            border: 1px solid rgba(0, 242, 255, 0.2);
            border-radius: 35px; padding: 35px;
            backdrop-filter: blur(20px);
            box-shadow: 0 0 50px rgba(0,0,0,1), 0 0 20px rgba(0, 242, 255, 0.1);
        }

        .header h1 {
            font-family: 'Orbitron', sans-serif; font-size: 1.4rem;
            text-align: center; letter-spacing: 4px;
            background: linear-gradient(90deg, var(--neon-blue), var(--neon-pink));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            margin-bottom: 30px;
        }

        .box {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px; padding: 20px; margin-bottom: 15px;
        }

        label {
            font-size: 0.7rem; color: var(--neon-blue);
            text-transform: uppercase; letter-spacing: 2px;
            display: block; margin-bottom: 10px;
        }

        .row { display: flex; align-items: center; gap: 10px; }

        input {
            flex: 1; background: none; border: none;
            color: #fff; font-size: 1.8rem; font-weight: 700;
            outline: none; width: 60%;
        }

        select {
            background: #111; color: #fff;
            border: 1px solid #334155; border-radius: 10px;
            padding: 8px; font-size: 0.85rem;
            width: 140px; cursor: pointer; outline: none;
        }

        .swap-container {
            display: flex; justify-content: center; margin: -5px 0 10px;
        }

        .swap-btn {
            width: 45px; height: 45px;
            background: linear-gradient(135deg, var(--neon-blue), var(--neon-pink));
            border-radius: 50%; display: flex; justify-content: center; align-items: center;
            cursor: pointer; transition: 0.4s; box-shadow: 0 0 15px rgba(255, 0, 127, 0.3);
        }
        .swap-btn:hover { transform: rotate(180deg); }

        .info-panel {
            text-align: center; margin-top: 25px;
            border-top: 1px solid rgba(255,255,255,0.05); padding-top: 20px;
        }

        #rate-text { font-size: 1.1rem; color: var(--neon-pink); font-weight: 700; }
        .status { font-size: 0.6rem; color: #444; margin-top: 10px; letter-spacing: 1px; }
    </style>
</head>
<body>

<div class="app-card">
    <div class="header"><h1>NEXA KURS</h1></div>

    <div class="box">
        <label>Dari Mata Uang</label>
        <div class="row">
            <input type="number" id="amount" value="1" oninput="convert()">
            <select id="fromCurrency" onchange="convert()"></select>
        </div>
    </div>

    <div class="swap-container">
        <div class="swap-btn" onclick="swap()"><i class="fas fa-sync-alt"></i></div>
    </div>

    <div class="box" style="border-color: rgba(255, 0, 127, 0.2);">
        <label>Hasil Konversi</label>
        <div class="row">
            <input type="text" id="result" readonly placeholder="0.00">
            <select id="toCurrency" onchange="convert()"></select>
        </div>
    </div>

    <div class="info-panel">
        <div id="rate-text">Memuat Data...</div>
        <div class="status">DATA SOURCE: EXCHANGE RATE API (LIVE)</div>
    </div>
</div>

<script>
    // Database mata uang lebih lengkap dengan nama negara
    const currencyData = {
        "USD": "United States Dollar", "IDR": "Indonesian Rupiah", "EUR": "Euro (EU)", "GBP": "British Pound", "JPY": "Japanese Yen",
        "AUD": "Australian Dollar", "CAD": "Canadian Dollar", "CHF": "Swiss Franc", "CNY": "Chinese Yuan", "HKD": "Hong Kong Dollar",
        "SGD": "Singapore Dollar", "KRW": "South Korean Won", "MYR": "Malaysian Ringgit", "THB": "Thai Baht", "PHP": "Philippine Peso",
        "VND": "Vietnamese Dong", "INR": "Indian Rupee", "SAR": "Saudi Riyal", "AED": "UAE Dirham", "RUB": "Russian Ruble",
        "BRL": "Brazilian Real", "TRY": "Turkish Lira", "ZAR": "South African Rand", "NZD": "New Zealand Dollar", "MXN": "Mexican Peso",
        "TWD": "Taiwan Dollar", "NOK": "Norwegian Krone", "DKK": "Danish Krone", "SEK": "Swedish Krona", "PLN": "Polish Zloty"
    };

    const fromSelect = document.getElementById('fromCurrency');
    const toSelect = document.getElementById('toCurrency');

    // Load options
    Object.entries(currencyData).sort().forEach(([code, name]) => {
        const opt = `<option value="${code}">${code} (${name})</option>`;
        fromSelect.innerHTML += opt;
        toSelect.innerHTML += opt;
    });

    fromSelect.value = "USD";
    toSelect.value = "IDR";

    async function convert() {
        const amount = document.getElementById('amount').value;
        const from = fromSelect.value;
        const to = toSelect.value;
        const info = document.getElementById('rate-text');
        
        if (!amount || amount <= 0) return;

        info.innerText = "SINKRONISASI...";
        try {
            const res = await fetch(`https://api.exchangerate-api.com/v4/latest/${from}`);
            const data = await res.json();
            const rate = data.rates[to];
            const result = (amount * rate).toLocaleString('id-ID', { minimumFractionDigits: 2 });
            
            document.getElementById('result').value = result;
            info.innerText = `1 ${from} = ${rate.toLocaleString('id-ID')} ${to}`;
        } catch (e) {
            info.innerText = "Gagal Mengambil Data Kurs";
        }
    }

    function swap() {
        const temp = fromSelect.value;
        fromSelect.value = toSelect.value;
        toSelect.value = temp;
        convert();
    }

    convert();
</script>
</body>
</html>
